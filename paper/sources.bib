@article{EffectofImmigrationProductivity,
    author = {Peri, Giovanni},
    title = {The Effect Of Immigration On Productivity: Evidence From U.S. States},
    journal = {The Review of Economics and Statistics},
    volume = {94},
    number = {1},
    pages = {348-358},
    year = {2012},
    month = {02},
    abstract = {In this paper we analyze the long-run impact of immigration on employment, productivity, and its skill bias. We use the existence of immigrant communities across U.S. states before 1960 and the distance from the Mexican border as instruments for immigration flows. We find no evidence that immigrants crowded out employment. At the same time, we find that immigration had a strong, positive association with total factor productivity and a negative association with the high skill bias of production technologies. The results are consistent with the idea that immigrants promoted efficient task specialization, thus increasing TFP, and also promoted the adoption of unskilled-efficient technologies.},
    issn = {0034-6535},
    doi = {10.1162/REST_a_00137},
    url = {https://doi.org/10.1162/REST_a_00137},
    eprint = {https://direct.mit.edu/rest/article-pdf/94/1/348/1916894/rest_a_00137.pdf},
}

@incollection{FirmDynamicsandImmigration,
publisher={National Bureau of Economic Research, Inc},
series={NBER Chapters},
edition={None},
booktitle={High-Skilled Migration to the United States and Its Economic Consequences},
author={Michael E. Waugh},
title={Firm Dynamics and Immigration: The Case of High-Skilled Immigration},
year={2017},
month={May},
pages={205-238},
abstract={This paper shows how the dynamics of the firm yield new insights into the short- and long-run economic outcomes from changes in immigration policy. I quantitatively illustrate these insights by evaluating two policies: an expansion of and the elimination of the H-1B visa program for skilled labor. A change in policy changes firmsâ€™ entry and exit decisions as they dynamically respond to changes in market size. The dynamic response of firms amplifies changes in relative wages as labor demand shifts with the distribution of firms. Firmsâ€™ responses also lead to the rapid accrual of aggregate gains/losses in output and consumption. The welfare implications of policy changes depend critically on who bears the burden of creating new firms.<br><small>(This abstract was borrowed from another version of this item.)</small>},
keywords={},
url={https://ideas.repec.org/h/nbr/nberch/13843.html},
}

@TechReport{ImmigrantsImportsAndWelfare,
type={RFBerlin Discussion Paper Series},
institution={Rockwool Foundation Berlin (RF Berlin)},
author={Brett McCully and Torsten Jaccard and Christoph Albert},
title={Immigrants, Imports, and Welfare: Evidence from Household Purchase Data},
year={2024},
month={Sep},
number={2417},
abstract={Do immigrants make goods from their origin country more accessible to their non-immigrant neighbors? We augment U.S. grocery scanner data to include the origin country of both households and products, thereby enabling the first direct estimate of how local immigrant presence affects import penetration. Using a quantitative model of trade, we show that immigrants increase the grocery import expenditure share by 8\%. Three quarters of this effect is attributable to immigrantsÃ¢â‚¬â„¢ own disproportionate preferences for imported goods. Immigrants therefore raise import expenditures primarily through their own consumption, with muted benefits for their non-immigrant neighbors. The benefits that do accrue to natives are concentrated within high-income and urban households.},
keywords={Import demand; immigrant preferences; household heterogeneity; spillovereffects},
doi={None},
url={https://ideas.repec.org/p/crm/wpaper/2417.html},
}

